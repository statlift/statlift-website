{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "has": [{ "type": "host", "value": "(www\\.)?statlift\\.net" }], "destination": "/en/index.html" },
    { "source": "/", "has": [{ "type": "host", "value": "(www\\.)?statlift\\.de" }], "destination": "/de/index.html" },
    
    { "source": "/zugang", "has": [{ "type": "host", "value": "(www\\.)?statlift\\.net" }], "destination": "/en/zugang.html" },
    { "source": "/feedback", "has": [{ "type": "host", "value": "(www\\.)?statlift\\.net" }], "destination": "/en/feedback.html" },
    { "source": "/zugang", "has": [{ "type": "host", "value": "(www\\.)?statlift\\.de" }], "destination": "/de/zugang.html" },
    { "source": "/feedback", "has": [{ "type": "host", "value": "(www\\.)?statlift\\.de" }], "destination": "/de/feedback.html" },
    
    { "source": "/(.*)", "has": [{ "type": "host", "value": "(www\\.)?statlift\\.net" }], "destination": "/en/$1" },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "(www\\.)?statlift\\.de" }], "destination": "/de/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
